# Configuração do Firebase (Auth Google + Firestore).
# Copie para `.env.local` e preencha com os valores do seu projeto Firebase:
#   Firebase Console → Project settings → Your apps → SDK setup and configuration.
# Estes valores NÃO são segredo (vão no bundle do cliente). A segurança vem das
# regras do Firestore (ver firestore.rules) e dos domínios autorizados no Auth.
#
# Sem estas variáveis, o site funciona normalmente — apenas sem login/sync.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
